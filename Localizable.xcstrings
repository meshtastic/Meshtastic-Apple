    "Only permitted for SENSOR, TRACKER and TAK_TRACKER roles, this will inhibit all rebroadcasts, not unlike CLIENT_MUTE role." : {
      "extractionState" : "stale",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "SENSOR、TRACKER、TAK_TRACKERロールでのみ許可されており、CLIENT_MUTEロールと同様にすべての再ブロードキャストを抑制します。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешено только для ролей SENSOR, TRACKER и TAK_TRACKER, это отключит все повторные передачи, как и роль CLIENT_MUTE."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дозвољено само за улоге SENSOR, TRACKER и TAK_TRACKER, ово ће онемогућити све поновне емитовања, слично као у улози CLIENT_MUTE."
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅允許用於 SENSOR、TRACKER 和 TAK_TRACKER 角色，啟用後會禁止所有訊息的重新廣播，效果類似於 CLIENT_MUTE 角色。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅适用于 SENSOR、TRACKER 和 TAK_TRACKER 角色。启用后会禁止所有重新广播，类似 CLIENT_MUTE 角色。"
          }
        }
      }
    },
    "Only rebroadcasts packets from the core portnums: NodeInfo, Text, Position, Telemetry, and Routing." : {
      "extractionState" : "stale",
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "コアポート番号からのパケットのみ再ブロードキャスト: ノード情報、テキスト、位置、テレメトリ、ルーティング。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Повторно передает только пакеты с основных портов: NodeInfo, Text, Position, Telemetry и Routing."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Поново емитује само пакете са основних портова: NodeInfo, Text, Position, Telemetry и Routing."
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "僅會重傳來自核心 portnum 的封包：NodeInfo、Text、Position、Telemetry 和 Routing"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "仅重新广播来自核心端口号的包：NodeInfo、Text、Position、Telemetry 和 Routing。"
          }
