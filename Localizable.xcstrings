    "Channel number must be between 0 and 7.": {
      "localizations": {
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il numero del canale deve essere compreso tra 0 e 7."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "チャンネル番号は0から7の間である必要があります。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Номер канала должен быть от 0 до 7."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "Број канала мора бити између 0 и 7."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "频道编号必须介于 0 和 7 之间。"
          }
        }
      }
    },
