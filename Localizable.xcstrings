        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "人が検出された時にメッシュにメッセージを送信する頻度。"
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "How often we can send a message to the mesh when people are detected."
          }
        },
        "se": {
