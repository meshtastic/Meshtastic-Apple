        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "El clave pública más reciente para este nodo no coincide con la clave previamente registrada. Verifique quién está enviando el mensaje comparando las claves públicas en persona o por teléfono."
