            "value" : "ユーザーボタンが押されたり、メッセージが受信された後、画面が点灯し続ける時間。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Как долго экран остается включенным после нажатия кнопки пользователя или получения сообщений."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Колико дуго екран остаје укључен након притиска корисничког дугмета или пријема порука."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
