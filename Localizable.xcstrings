    "Long press to favorite or mute the contact or delete a conversation.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Durch langes Gedrückthalten kannst du den Kontakt zu deinen Favoriten hinzufügen, stumm schalten oder eine Unterhaltung löschen."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Premere a lungo per privilegiare o silenziare il contatto o eliminare una conversazione."
