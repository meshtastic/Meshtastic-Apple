        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Enviar un mensaje de grupo Meshtastic - enviar un mensaje a un canal de red mesh"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
