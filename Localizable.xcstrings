    },
    "A channel index of 0 indicates the primary channel where broadcast packets are sent. Location data is broadcast from the first channel where it is enabled with firmware 2.7 forward." : {
      "comment" : "Description of the primary channel, which is the channel used for broadcasting location data.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein Kanalindex von 0 weist auf den Hauptkanal hin, von dem Broadcastpakete gesendet werden. Die Standortdaten werden von dem ersten Kanal gesendet, der mit Firmware 2.7 oder höher aktiviert ist."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un índice de canal de 0 indica el canal principal donde se envían los paquetes de transmisión. Los datos de ubicación se transmiten desde el primer canal donde está habilitado con el firmware 2.7 adelante."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un indice di canale di 0 indica il canale principale dove vengono inviati i pacchetti di trasmissione. I dati di posizione vengono trasmessi dal primo canale dove sono abilitati con il firmware 2.7 avanti."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "0表示广播包发送的优先通道，位置数据在2.7版本后启用的第一通道广播。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "0 表示主頻道，使用來發送播報包。位置數據從第一個被啟用且支援 2.7 版本的頻道中發送。"
          }
        }
      }
    },
    "A default self-signed certificate is included for localhost connections. Import a custom .p12 if needed. Client CA (.pem) validates connecting TAK clients." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein Standard-Zertifikat mit eigenem Schlüssel wird für Verbindungen über localhost bereitgestellt. Falls erforderlich, importiere ein individuelles .p12. Das Client-CA (.pem) validiert die Verbindung zu TAK-Clients."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Se incluye un certificado self-signed predeterminado para conexiones a localhost. Importa un .p12 personalizado si es necesario. El CA del cliente (.pem) valida la conexión de clientes TAK."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un certificato auto-firmato predefinito è incluso per le connessioni localhost. Importa un .p12 personalizzato se necessario. Il CA del client (.pem) valida il collegamento ai client TAK."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "本地连接使用默认自签证书，需要时可以导入自定义.p12文件。客户端CA(.pem)验证连接 TAK 客户端。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "本地連線使用預設的自簽證書，若需，請導入自訂的.p12文件。客戶端CA(.pem)會驗證連接 TAK 客戶端。"
          }
        }
      }
    },
    "A previous position report for this node." : {
      "comment" : "A description of a position history point.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein vorheriger Positionsbericht für diesen Knotenpunkt"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un informe de posición anterior para este nodo."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un precedente rapporto di posizione per questo nodo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "此节点的上一份位置报告"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "此節點的上一份位置報告"
          }
        }
      }
    },
    "A previous position report showing the direction of travel." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein vorheriges Positionsbericht zeigt die Richtung des Reisewegs."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un informe anterior de posición mostrando la dirección de viaje."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un rapporto di posizione precedente che mostra la direzione di viaggio."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "上一份位置报告显示了旅行方向。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "上一張位置報告顯示移動方向。"
          }
        }
      }
    },
    "A QR code contains the LoRa config and channels needed for radios to communicate. Use Replace Channels to overwrite or Add Channels to append to existing channels." : {
      "comment" : "A description of the QR code and channels.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein QR-Code enthält die LoRa-Konfiguration und die Kanäle, die für Radios zum Kommunizieren benötigt werden. Verwenden Sie `Kanäle ersetzen`, um vorhandene Kanäle zu überschreiben, oder `Kanäle hinzufügen`, um vorhandene Kanäle zu erweitern."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un código QR contiene la configuración LoRa y los canales necesarios para que los radios puedan comunicarse. Usa Sustituir Canales para reemplazar o Agregar Canales para añadir a los canales existentes."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un codice QR contiene la configurazione LoRa e i canali necessari per le radio per comunicare. Usa Sostituisci Canali per sovrascrivere o Aggiungi Canali per aggiungere ai canali esistenti."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "二维码包含LoRa配置和用于无线通信的频道。使用替换频道将覆盖或添加现有频道。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "QR碼包含 LoRa 配置和無線電之間的通信所需的頻道。使用替換頻道來覆蓋或添加現有頻道。"
          }
        }
      }
    },
    "A shared point of interest. Long-press the map to create one." : {
      "comment" : "A description of a waypoint.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein gemeinsamer Treffpunkt. Halte die Karte lange gedrückt, um einen zu erstellen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un punto de interés compartido. Mantenga presionado el mapa para crear uno."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Un punto di interesse condiviso. Premere a lungo sul mappa per crearne uno."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "一个共享的兴趣点。长按地图创建一个。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "共享景點。長按地圖來建立一個。"
          }
        }
      }
    },
    "A Trace Route was sent, no response has been received." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der er igangsat en rutesporing (trace route), men der er ikke modtaget svar."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Eine Trace Route wurde gesendet, keine Antwort wurde empfangen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Un Trace Route fue enviado, no se ha recibido respuesta."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "È stata inviata una rotta di tracciamento, ma non è stata ricevuta alcuna risposta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trace Route が送信されましたが、応答が受信されませんでした。"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Был отправлен запрос трассировки маршрута, ответа получено не было."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Трејсрут је послат, али одговор није примљен."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "一条路径追踪被发送，没有收到响应。"
          }
        },
        "zh-Hant-TW" : {
