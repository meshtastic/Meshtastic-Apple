    "In addition to Config, Keys and BLE bonds will be wiped" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Außerdem werden Config, Keys und BLE-Bonds gelöscht"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Además de la configuración, se borrarán las claves y los enlaces BLE."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Oltre a Config, Chiavi e legami BLE verranno cancellati"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Помимо конфигурации, будут стерты ключи и связи BLE."
          }
        },
        "sr" : {
