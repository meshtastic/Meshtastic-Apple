    "Currently the recommended way to update ESP32 devices is using the web flasher on a desktop computer from a chrome based browser. It does not work on mobile devices or over BLE." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Attualmente il modo consigliato per aggiornare i dispositivi ESP32 √® quello di utilizzare il flasher web su un computer desktop da un browser basato su chrome. Non funziona su dispositivi mobili o tramite BLE."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ÁŹĺŚú®„ÄĀESP32„Éá„Éź„ā§„āĻ„ĀģśõīśĖį„Āģśé®Ś•®śĖĻś≥ē„ĀĮ„ÄĀ„Éá„āĻ„āĮ„Éą„ÉÉ„Éó„ā≥„É≥„ÉĒ„É•„Éľ„āŅ„Éľ„ĀģChrome„Éô„Éľ„āĻ„Āģ„ÉĖ„É©„ā¶„ā∂„Éľ„ĀßWeb„Éē„É©„ÉÉ„ā∑„É£„Éľ„āíšĹŅÁĒ®„Āô„āč„Āď„Ā®„Āß„Āô„Äā„ÉĘ„Éź„ā§„Éę„Éá„Éź„ā§„āĻ„āĄBLEÁĶĆÁĒĪ„Āß„ĀĮŚčēšĹú„Āó„Āĺ„Āõ„āď„Äā"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "–Ę—Ä–Ķ–Ĺ—É—ā–Ĺ–ĺ –Ņ—Ä–Ķ–Ņ–ĺ—Ä—É—á–Ķ–Ĺ–ł –Ĺ–į—á–ł–Ĺ –∑–į –į–∂—É—Ä–ł—Ä–į—ö–Ķ –ē–°–ü32 —É—Ä–Ķ—í–į—ė–į —ė–Ķ –ļ–ĺ—Ä–ł—ą—õ–Ķ—ö–Ķ –≤–Ķ–Ī —Ą–Ľ–Ķ—ą–Ķ—Ä–į –Ĺ–į –ī–Ķ—Ā–ļ—ā–ĺ–Ņ —Ä–į—á—É–Ĺ–į—Ä—É –ł–∑ –Ņ—Ä–Ķ–≥–Ľ–Ķ–ī–į—á–į –∑–į—Ā–Ĺ–ĺ–≤–į–Ĺ–ĺ–≥ –Ĺ–į —Ö—Ä–ĺ–ľ—É. –Ě–Ķ —Ä–į–ī–ł –Ĺ–į –ľ–ĺ–Ī–ł–Ľ–Ĺ–ł–ľ —É—Ä–Ķ—í–į—ė–ł–ľ–į –ł–Ľ–ł –Ņ—Ä–Ķ–ļ–ĺ BLE-–į."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ÁõģŚČćÔľĆśõīśĖį ESP32 ŤģĺŚ§áÁöĄśé®ŤćźśĖĻś≥ēśėĮŚú®ÁĒĶŤĄĎšłäšĹŅÁĒ®Śüļšļé Chrome śĶŹŤßąŚô®ÁöĄ Web Flasher„ÄāŤĮ•śĖĻś≥ēšłćťÄāÁĒ®šļéÁßĽŚä®ŤģĺŚ§áśąĖťÄöŤŅá BLE ŤŅõŤ°ĆśõīśĖį„Äā"
          }
