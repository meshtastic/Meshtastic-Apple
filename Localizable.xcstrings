    "ESP32 OTA updating requires firmware %@ or later. Update your device firmware using the Web Flasher first." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Das OTA-Aktualisieren des ESP32 erfordert ein Firmware %@ oder höher. Aktualisiere zuerst das Firmware deines Geräts mit dem Web Flasher."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La actualización OTA del ESP32 requiere el firmware %@ o posterior. Actualice el firmware de su dispositivo utilizando el Web Flasher primero."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La mise à jour OTA de l'ESP32 nécessite un firmware %@ ou plus récent. Mettez à jour le firmware de votre appareil en utilisant le Web Flasher en premier lieu."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Aggiornamento firmware OTA di ESP32 richiede firmware %@ o successivo. Aggiorna il firmware del tuo dispositivo utilizzando il Web Flasher per primo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ESP32 OTA更新には、%@または後のファームウェアが必要です。Web Flasherを使用してデバイスのファームウェアを更新してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ESP32 OTA 업데이트에는 %@ 또는 최신 버전을 사용하는 것이 필요합니다. Web Flasher를 사용하여 먼저 장치의 소프트웨어 버전을 업데이트하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Atualizar o firmware OTA do ESP32 requer o firmware %@ ou superior. Atualize o firmware do seu dispositivo usando o Web Flasher primeiro."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ESP32 OTA 更新需要 %@ 或更高版本的固件。先使用 Web Flasher 更新设备固件。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ESP32 OTA 更新需要 %@ 或更新的軟體。先使用 Web Flasher 更新設備軟體。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "ESP32 OTA 更新需要 %@ 或更高版本的軟體更新。先使用 Web Flasher 更新設備的軟體版本。"
          }
        }
      }
    },
