    "Connecting to a new radio will clear all app data on the phone." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis du tilslutter en ny radio bliver all appens data på telefonen slettet"
          }
        },
        "de" : {
          "stringUnit" : {
