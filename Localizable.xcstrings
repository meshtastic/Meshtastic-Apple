        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "šĹŅÁĒ®ŤÄÖśĆČšłčśĆČťąēśąĖśĒ∂ŚąįŤ®äśĀĮŚĺĆÔľĆŤěĘŚĻēÁ∂≠śĆĀšļģŤĶ∑ÁöĄśôāťĖďťē∑Śļ¶„Äā"
