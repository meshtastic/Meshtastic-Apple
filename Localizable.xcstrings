          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "–®—ā–į —Ä–į–ī–ł —Ä–Ķ–∂–ł–ľ –Ľ–ł—Ü–Ķ–Ĺ—Ü–ł—Ä–į–Ĺ–ĺ–≥ –ĺ–Ņ–Ķ—Ä–į—ā–Ķ—Ä–į:\n* –ü–ĺ—Ā—ā–į–≤—ô–į –ł–ľ–Ķ —á–≤–ĺ—Ä–į –Ĺ–į –≤–į—ą –Ņ–ĺ–∑–ł–≤–Ĺ–ł –∑–Ĺ–į–ļ\n* –ē–ľ–ł—ā—É—ė–Ķ –ł–Ĺ—Ą–ĺ—Ä–ľ–į—Ü–ł—ė–Ķ –ĺ —á–≤–ĺ—Ä—É —Ā–≤–į–ļ–ł—Ö 10 –ľ–ł–Ĺ—É—ā–į\n* –ü—Ä–Ķ–≤–į–∑–ł–Ľ–į–∑–ł —Ą—Ä–Ķ–ļ–≤–Ķ–Ĺ—Ü–ł—ė—É, —Ü–ł–ļ–Ľ—É—Ā —Ä–į–ī–į –ł –ł–∑–Ľ–į–∑–Ĺ—É —Ā–Ĺ–į–≥—É\n* –ě–Ĺ–Ķ–ľ–ĺ–≥—É—õ–į–≤–į –Ķ–Ĺ–ļ—Ä–ł–Ņ—Ü–ł—ė—É"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "šłöšĹôśó†ÁļŅÁĒĶś®°ŚľŹÁöĄšĹúÁĒ®Ôľö\n* ŚįÜŤäāÁāĻŚźćÁßįŤģĺÁĹģšłļśā®ÁöĄŚĎľŚŹ∑ \n* śĮŹ 10 ŚąÜťíüŚĻŅśí≠šłÄś¨°ŤäāÁāĻšŅ°śĀĮ \n* Ť¶ÜÁõĖťĘĎÁéá„ÄĀŚć†Á©ļśĮĒŚíĆŚŹĎŚįĄŚäüÁéá \n* Á¶ĀÁĒ®Śä†ŚĮÜ"
