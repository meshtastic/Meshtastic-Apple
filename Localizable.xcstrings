    "%@ config data was requested via PKC admin but no response has been returned from the remote node." : {
      "localizations" : {
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ данные конфигурации были запрошены через PKC admin, но ответа от удаленной ноды получено не было."
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ конфигурациони подаци су захтевани преко ПКЦ администратора, али није добијен одговор са удаљеног чвора."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "已通过 PKC 管理请求 %@ 的配置数据，但远程节点未返回响应。"
