          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您所在地区的占空比为 %lld%%。在占空比受限的情况下，不建议使用 MQTT，因为额外的流量会很快压垮您的 LoRa 网格。"
          }
        },
        "zh-Hant-TW" : {
