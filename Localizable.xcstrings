    " Send Reboot into DFU" : {
      "comment" : "A button that sends",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Senden Sie einen Neustart in DFU"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Enviar reinicio a DFU"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Invia il Reboot in DFU"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
