        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "您的mPWRD-OS设备已连接到Wi-Fi网络。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
