    "\"Send a Meshtastic direct message\" — send a private message to a node." : {
      "comment" : "A description of how to send a direct message to a node using Siri.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sende eine private Nachricht an einen Meshtastic-Node."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Enviar un mensaje directo de Meshtastic"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Invia un messaggio diretto a Meshtastic - invia un messaggio privato a un nodo."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "发送Meshtastic直接消息 - 私信一个节点"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "使用 Siri 向 Meshtastic 節點發送直接訊息"
          }
        }
      }
    },
    "\"Send a Meshtastic group message\" — send a message to a mesh channel." : {
