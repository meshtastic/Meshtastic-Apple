        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ÁČĻ„Āę„ÉÜ„É¨„É°„Éą„É™„Ā®šĹćÁĹģśÉÖŚ†Ī„Āģ„Āô„ĀĻ„Ā¶„ĀģŚģöśúü„ÉĖ„É≠„Éľ„ÉČ„ā≠„É£„āĻ„ÉąťĖďťöĒ„āíŚą∂ťôź„Āó„Āĺ„Āô„Äā„Éõ„ÉÉ„Éó„āíŚĘó„āĄ„ĀôŚŅÖŤ¶Ā„ĀĆ„Āā„āčŚ†īŚźą„ĀĮ„ÄĀšł≠Ś§ģ„Āģ„Éé„Éľ„ÉČ„Āß„ĀĮ„Ā™„ĀŹÁęĮ„Āģ„Éé„Éľ„ÉČ„ĀßŤ°Ć„Ā£„Ā¶„ĀŹ„Ā†„Āē„ĀĄ„Äā„Éá„É•„Éľ„ÉÜ„ā£„āĶ„ā§„āĮ„Éę„ĀĆŚą∂ťôź„Āē„āĆ„Ā¶„ĀĄ„āčŚ†īŚźą„ÄĀ„ā≤„Éľ„Éą„ā¶„āß„ā§„Éé„Éľ„ÉČ„ĀĆ„Āô„ĀĻ„Ā¶„ĀģšĹúś•≠„āíŤ°Ć„ĀÜ„Āü„āĀ„ÄĀMQTT„ĀĮśé®Ś•®„Āē„āĆ„Āĺ„Āõ„āď„Äā"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "–ě–≥—Ä–į–Ĺ–ł—á–ł—ā–Ķ —Ā–≤–Ķ –Ņ–Ķ—Ä–ł–ĺ–ī–ł—á–Ĺ–Ķ –ł–Ĺ—ā–Ķ—Ä–≤–į–Ľ–Ķ –Ķ–ľ–ł—ā–ĺ–≤–į—ö–į, –Ņ–ĺ—Ā–Ķ–Ī–Ĺ–ĺ —ā–Ķ–Ľ–Ķ–ľ–Ķ—ā—Ä–ł—ė—É –ł –Ņ–ĺ–∑–ł—Ü–ł—ė—É. –ź–ļ–ĺ —ė–Ķ –Ņ–ĺ—ā—Ä–Ķ–Ī–Ĺ–ĺ –Ņ–ĺ–≤–Ķ—õ–į—ā–ł –Ī—Ä–ĺ—ė —Ā–ļ–ĺ–ļ–ĺ–≤–į, —ā–ĺ —Ä–į–ī–ł—ā–Ķ –Ĺ–į —á–≤–ĺ—Ä–ĺ–≤–ł–ľ–į –Ĺ–į –ł–≤–ł—Ü–į–ľ–į, –į –Ĺ–Ķ –Ĺ–į –ĺ–Ĺ–ł–ľ —É —Ā—Ä–Ķ–ī–ł–Ĺ–ł. MQTT –Ĺ–ł—ė–Ķ –Ņ—Ä–Ķ–Ņ–ĺ—Ä—É—á–Ķ–Ĺ –ļ–į–ī–į —Ā—ā–Ķ –ĺ–≥—Ä–į–Ĺ–ł—á–Ķ–Ĺ–ł —Ü–ł–ļ–Ľ—É—Ā–ĺ–ľ –ī—É–∂–Ĺ–ĺ—Ā—ā–ł —ė–Ķ—Ä —É —ā–ĺ–ľ —Ā–Ľ—É—á–į—ė—É —á–≤–ĺ—Ä-—Ä—É—ā–Ķ—Ä —Ä–į–ī–ł —Ā–į–≤ –Ņ–ĺ—Ā–į–ĺ."
          }
