        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Документација ажурирања фирмвера методом превуци-и-испусти"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
