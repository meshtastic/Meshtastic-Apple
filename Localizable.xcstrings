    "Sets the maximum number of hops, default is 3. Increasing hops also increases congestion and should be used carefully. O hop broadcast messages will not get ACKs." : {
      "localizations" : {
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Imposta il numero massimo di hop, l'impostazione predefinita √® 3. L'aumento degli hop aumenta anche la congestione e deve essere usato con attenzione. I messaggi di broadcasting a un hop non riceveranno ACK."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "śúÄŚ§ß„Éõ„ÉÉ„Éóśēį„āíŤ®≠Śģö„Āó„Āĺ„Āô„Äā„Éá„Éē„ā©„Éę„Éą„ĀĮ3„Āß„Āô„Äā„Éõ„ÉÉ„Éóśēį„āíŚĘó„āĄ„Āô„Ā®ŤľĽŤľ≥„āāŚĘóŚä†„Āô„āč„Āü„āĀ„ÄĀśÖéťáć„ĀęšĹŅÁĒ®„Āó„Ā¶„ĀŹ„Ā†„Āē„ĀĄ„Äā0„Éõ„ÉÉ„Éó„Āģ„ÉĖ„É≠„Éľ„ÉČ„ā≠„É£„āĻ„Éą„É°„ÉÉ„āĽ„Éľ„āł„ĀĮACK„āíŚŹóšŅ°„Āó„Āĺ„Āõ„āď„Äā"
          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "–ü–ĺ–ī–Ķ—ą–į–≤–į –ľ–į–ļ—Ā–ł–ľ–į–Ľ–į–Ĺ –Ī—Ä–ĺ—ė —Ā–ļ–ĺ–ļ–ĺ–≤–į. –ü–ĺ–ī—Ä–į–∑—É–ľ–Ķ–≤–į–Ĺ–ĺ —ė–Ķ 3, –į –Ņ–ĺ–≤–Ķ—õ–į—ö–Ķ –Ī—Ä–ĺ—ė–į –ĺ–ī–ĺ–Ī—Ä–Ķ–Ĺ–ł—Ö —Ā–ļ–ĺ–ļ–ĺ–≤–į —ā–į–ļ–ĺ—í–Ķ –Ņ–ĺ–≤–Ķ—õ–į–≤–į –∑–į–≥—É—ą–Ķ—ö–Ķ –ł —ā—Ä–Ķ–Ī–į –≥–į –ļ–ĺ—Ä–ł—Ā—ā–ł—ā–ł –ĺ–Ņ—Ä–Ķ–∑–Ĺ–ĺ. –ü–ĺ—Ä—É–ļ–Ķ –Ķ–ľ–ł—ā–ĺ–≤–į–Ĺ–Ķ —Ā–į 0 —Ā–ļ–ĺ–ļ–ĺ–≤–į –Ĺ–Ķ—õ–Ķ –ī–ĺ–Ī–ł—ā–ł –Ņ–ĺ—ā–≤—Ä–ī–Ķ –Ņ—Ä–ł—ė–Ķ–ľ–į (ACK)."
          }
        },
        "zh-Hant-TW" : {
