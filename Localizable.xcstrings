    "%@ config data was requested via PKC admin but no response has been returned from the remote node.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ данные конфигурации были запрошены через PKC admin, но ответа от удаленного узла получено не было."
          }
        },
        "sr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ конфигурациони подаци су захтевани преко ПКЦ администратора, али није добијен одговор са удаљеног чвора."
          }
        }
      }
    },
