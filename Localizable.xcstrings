    },
    "A channel index of 0 indicates the primary channel where broadcast packets are sent. Location data is broadcast from the first channel where it is enabled with firmware 2.7 forward." : {
      "comment" : "Description of the primary channel, which is the channel used for broadcasting location data.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein Kanalindex von 0 weist auf den Hauptkanal hin, von dem Broadcastpakete gesendet werden. Die Standortdaten werden von dem ersten Kanal gesendet, der mit Firmware 2.7 oder höher aktiviert ist."
          }
        }
      }
    },
    "A default self-signed certificate is included for localhost connections. Import a custom .p12 if needed. Client CA (.pem) validates connecting TAK clients." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein Standard-Zertifikat mit eigenem Schlüssel wird für Verbindungen über localhost bereitgestellt. Falls erforderlich, importiere ein individuelles .p12. Das Client-CA (.pem) validiert die Verbindung zu TAK-Clients."
          }
        }
      }
    },
    "A previous position report for this node." : {
      "comment" : "A description of a position history point.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein vorheriger Positionsbericht für diesen Knotenpunkt"
          }
        }
      }
    },
    "A previous position report showing the direction of travel." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein vorheriges Positionsbericht zeigt die Richtung des Reisewegs."
          }
        }
      }
    },
    "A QR code contains the LoRa config and channels needed for radios to communicate. Use Replace Channels to overwrite or Add Channels to append to existing channels." : {
      "comment" : "A description of the QR code and channels.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein QR-Code enthält die LoRa-Konfiguration und die Kanäle, die für Radios zum Kommunizieren benötigt werden. Verwenden Sie `Kanäle ersetzen`, um vorhandene Kanäle zu überschreiben, oder `Kanäle hinzufügen`, um vorhandene Kanäle zu erweitern."
          }
        }
      }
    },
    "A shared point of interest. Long-press the map to create one." : {
      "comment" : "A description of a waypoint.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Ein gemeinsamer Treffpunkt. Halte die Karte lange gedrückt, um einen zu erstellen."
          }
        }
      }
    },
    "A Trace Route was sent, no response has been received." : {
      "localizations" : {
