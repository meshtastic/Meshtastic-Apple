          }
        },
        "sr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Такође можете ажурирати свој Мештастик уређај преко блутута користећи Nordic DFU апликацију."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您还可以使用 Nordic DFU 应用程序通过蓝牙更新 Meshtastic 设备。"
          }
