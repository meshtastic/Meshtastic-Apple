    "SNR is above the limit for the current modem preset. Strong, reliable signal." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der SNR liegt über dem Grenzwert für die aktuelle Modemkonfiguration. Starkes, zuverlässiges Signal."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La señal es superior al límite para el preset de módem actual. Señal fuerte y confiable."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "SNR supera il limite per il preset modem corrente. Signal forte e affidabile."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "当前模组预设下SNR已超过限制，信号强劲可靠"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "信號強度超過目前模組預設的限制，信號穩定可靠"
          }
        }
      }
    },
    "SNR is far below the modem preset limit. Communication is unlikely at this signal level." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der SNR liegt weit unter dem voreingestellten Modem-Grenzwert. Eine Kommunikation ist bei diesem Signalpegel unwahrscheinlich."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La SNR está muy por debajo del límite predeterminado del módem. La comunicación es poco probable a este nivel de señal."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La SNR è molto inferiore al limite di impostazione del modem. La comunicazione è improbabile a questo livello di segnale."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "信噪比远低于模组预设限制，通信在这样的信号水平下不太可能"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "信噪比遠低於模組預設限制，通信在這個信號水平下很難進行"
          }
        }
      }
    },
    "SNR is slightly below the modem preset limit. Connection may be intermittent." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der SNR liegt leicht unter dem Modem-Einstellungenlimit. Die Verbindung kann intermittierend sein."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "El SNR está ligeramente por debajo del límite predefinido del módem. La conexión puede ser intermitente."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La SNR è leggermente sotto il limite di impostazione del modem. La connessione potrebbe essere intermittente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "信噪比略低于模组预设限值，连接可能不稳定。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "信噪比略低於模組預設限制，連線可能不穩定"
          }
        }
      }
    },
    "SNR is well below the modem preset limit. Expect packet loss and unreliable delivery." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Der SNR liegt deutlich unter dem voreingestellten Modem-Grenzwert. Sie können Pakettverluste und eine unzuverlässige Lieferung erwarten."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La SNR está muy por debajo del límite predeterminado del módem. Espere pérdida de paquetes y entrega poco confiable."
