    "Local Mesh Discovery requires the primary channel to use the default key. Please reset your primary channel key to the default before scanning." : {
      "comment" : "A message displayed when the primary channel is not using the default key.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Die Lokalisierung des Mesh-Entdeckers erfordert, dass der primäre Kanal die Standard-Schlüssel verwendet. Bitte aktualisiere den Schlüssel deines primären Kanals auf den Standardwert, bevor du scannst."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La Localización de Redes Mesh requiere que el canal principal use la clave predeterminada. Por favor, restablezca la clave del canal principal a la predeterminada antes de escanear."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "La scoperta del mesh locale richiede che il canale principale utilizzi la chiave predefinita. Per favore, ripristinare la chiave del canale principale alla predefinita prima di effettuare la scansione."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Mesh Discovery 需要主频使用默认密钥。请重置您的主频密钥为默认值，然后进行扫描。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "本地網格發現需要主頻使用預設密碼。請重設主頻密碼為預設後再掃描。"
          }
        }
      }
    },
