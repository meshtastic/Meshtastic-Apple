            "value": "Abilita la trasmissione di pacchetti via UDP sulla rete locale."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ローカルネットワーク上でUDP経由のパケットブロードキャストを有効にします。"
          }
        },
        "sr": {
          "stringUnit": {
