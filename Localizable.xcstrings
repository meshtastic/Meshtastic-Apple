    "Shows direction and distance to a node based on GPS positions. Requires both your device and the remote node to share location." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Zeigt die Richtung und Entfernung zu einem Knoten basierend auf GPS-Positionen. Erfordert, dass sowohl dein Gerät als auch der entfernte Knoten die Standortdaten teilen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Muestra la dirección y la distancia a un nodo basado en las posiciones GPS. Requiere que tanto tu dispositivo como el nodo remoto compartan su ubicación."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Affiche la direction et la distance vers un nœud en fonction des positions GPS. Il faut que votre appareil et le nœud distant partagent leur localisation."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Mostra la direzione e la distanza verso un nodo in base alle posizioni GPS. Richiede che sia il tuo dispositivo e il nodo remoto a condividere la posizione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "GPS位置に基づいてノードの方向と距離を表示します。デバイスの両方が位置を共有する必要があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "GPS 위치 기반 노드 방향 및 거리 표시. 장치와 원격 노드가 위치 공유를 요구합니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Mostra a direção e a distância para um nó com base nas posições GPS. Requer que ambos os dispositivos compartilhem a localização."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "根据GPS位置显示节点方向和距离。需要您的设备和远程节点共享位置。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "顯示對節點的導航方向和距離，根據GPS位置計算。需要您的設備和遠端節點共享位置。"
          }
        },
        "zh-Hant-TW" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "顯示基於GPS位置的節點方向和距離。需要您的設備和遠端節點共享位置。"
          }
        }
      }
    },
    "Shows the map legend." : {
      "localizations" : {
        "de" : {
