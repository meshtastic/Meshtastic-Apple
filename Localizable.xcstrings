      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "needs_review",
            "value" : "Sende eine Meshtastic-Gruppe-Nachricht - sende eine Nachricht an einen Mesh-Kanal"
          }
        }
      }
    },
    "\"Shut down my Meshtastic node\" or \"Restart my Meshtastic node\"." : {
