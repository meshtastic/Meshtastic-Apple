          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Включает автоматическую передачу TAK PLI и сокращает регулярные передачи."
          }
        },
        "se" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aktiverar automatiska TAK PLI-utsändningar och minskar rutinutsändningar."
          }
        },
        "sr" : {
          "stringUnit" : {
